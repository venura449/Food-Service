# Copy to .env and adjust for your machine
PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/foodorder
JWT_SECRET=change-this-to-a-long-random-string

# Single admin account (auto-created if missing). Sign-in only — not via /register.
ADMIN_EMAIL=admin@foodorder.local
ADMIN_PASSWORD=Admin123!

# Dish photos are saved under backend/uploads/menu/ (served at /uploads/menu/...).

# Stripe (test / sandbox)
STRIPE_SECRET_KEY=sk_test_xxx
